    libspandsp2 \
    libtiff6 \
    libsofia-sip-ua0 \
    uuid-runtime \
    libpython3.11 \
    libpq5 \
    libicu72 \
    libavcodec59 \
    libavformat59 \
    libavutil57 \
    libswscale6 \
    libyaml-0-2 \
    libpng16-16 \
    libv8-dev \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r freeswitch && useradd -r -g freeswitch freeswitch

COPY freeswitch-backup.tar.gz /tmp/
RUN tar -xzf /tmp/freeswitch-backup.tar.gz -C /usr/local/ && \
    rm /tmp/freeswitch-backup.tar.gz && \
    chown -R freeswitch:freeswitch /usr/local/freeswitch

EXPOSE 5060/udp 5060/tcp 5080/udp 5080/tcp 8021/tcp 16384-32768/udp

CMD ["/usr/local/freeswitch/bin/freeswitch", "-u", "freeswitch", "-g", "freeswitch", "-nonat", "-nf"]
EOF
